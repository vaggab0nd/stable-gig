# ── Gemini ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Supabase ────────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=          # "anon" public key  — used for user-facing queries (RLS enforced)
SUPABASE_SERVICE_KEY=       # "service_role" key — used for admin operations (bypasses RLS)

# ── Smarty (US Address Autocomplete) ───────────────────────────────────────────
# Sign up at https://www.smarty.com/ → API Keys → Secret Key pair
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=
