# ── Vertical ────────────────────────────────────────────────────────────────────
# Controls domain labels, AI prompts, and job categories.
# Options: home_repair (default) | vehicle_damage
VERTICAL=home_repair

# ── Gemini ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Anthropic (Claude) ──────────────────────────────────────────────────────────
# Used ONLY by the review-sentiment Supabase Edge Function.
# NOT needed in this .env file / Cloud Run — add it in:
#   Supabase Dashboard → Project Settings → Edge Functions → Secrets
# ANTHROPIC_API_KEY=

# ── Supabase ────────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=          # eyJ... (anon/public key — safe to expose client-side)
SUPABASE_SERVICE_KEY=       # eyJ... (service_role key — keep secret, bypasses RLS)

# ── Smarty (US Address Autocomplete) ───────────────────────────────────────────
# Sign up at https://www.smarty.com/ → API Keys → Secret Key pair
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=

# ── Stripe ──────────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=          # sk_live_... or sk_test_...
STRIPE_PUBLISHABLE_KEY=     # pk_live_... or pk_test_... (safe to expose client-side)
STRIPE_WEBHOOK_SECRET=      # whsec_... from Stripe Dashboard → Webhooks
